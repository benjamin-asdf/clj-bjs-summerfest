# Config sourced by deploy/start/stop/tunnel scripts.
# Override per-host by copying to deploy.local.env and editing there.

# SSH target (must resolve via ~/.ssh/config or be a full user@host).
REMOTE_HOST="${REMOTE_HOST:-linode}"

# Where the code + state live on the remote.
REMOTE_ROOT="${REMOTE_ROOT:-/opt/summerfest}"

# Path under which the app is mounted (matches nginx location).
BASE_PATH="${BASE_PATH:-/summerfest}"

# Loopback-only ports on the remote (nginx proxies to APP_PORT, NREPL is tunneled).
APP_PORT="${APP_PORT:-8096}"
NREPL_PORT="${NREPL_PORT:-7888}"

# Local port for `repl-tunnel.sh`.
LOCAL_NREPL_PORT="${LOCAL_NREPL_PORT:-7888}"

# Postgres on the remote (defaults match scripts/remote/install-pg.sh).
DB_HOST="${DB_HOST:-127.0.0.1}"
DB_PORT="${DB_PORT:-5432}"
DB_NAME="${DB_NAME:-summerfest}"
DB_USER="${DB_USER:-summerfest}"
DB_PASSWORD="${DB_PASSWORD:-summerfest}"

# SESSION_SECRET is NOT defined here. It lives on the server in
# $REMOTE_ROOT/.env (see scripts/remote/start.sh and the README), so a leaked
# repo or dev machine can't forge sessions. Bootstrap once per environment:
#   ssh $REMOTE_HOST 'umask 077 && \
#     echo "SESSION_SECRET=$(openssl rand -base64 32)" >> /opt/summerfest/.env'
